class BankTask extends Thread {

    private String taskName;

    public BankTask(String taskName) {
        this.taskName = taskName;
    }

    @Override
    public void run() {

        try {
            Thread.sleep(2000);
        } catch (InterruptedException e) {
        }

        System.out.println("✓ " + taskName + " Completed");
    }
}

public class BankWithThread {

    public static void main(String[] args) throws Exception {

        long start = System.currentTimeMillis();

        Thread t1 = new BankTask("Customer Profile");
        Thread t2 = new BankTask("Account Balance");
        Thread t3 = new BankTask("Transactions");
        Thread t4 = new BankTask("Loan Information");
        Thread t5 = new BankTask("Fraud Detection");

        t1.start();
        t2.start();
        t3.start();
        t4.start();
        t5.start();

        // Wait until all threads finish
        t1.join();
        t2.join();
        t3.join();
        t4.join();
        t5.join();

        long end = System.currentTimeMillis();

        System.out.println("--------------------------------");
        System.out.println("Dashboard Loaded");
        System.out.println("Total Time : " + (end - start) + " ms");
    }
}